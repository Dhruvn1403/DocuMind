{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "verbatimModuleSyntax": false,
        "isolatedModules": false
    },
    "include": [
        "src",
        "demo.ts"
    ]
}